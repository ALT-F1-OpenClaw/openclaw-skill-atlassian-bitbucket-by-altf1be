# Required — API tokens (recommended, replaces App Passwords)
# Get your token at: https://id.atlassian.com/manage-profile/security/api-tokens
BITBUCKET_EMAIL=you@example.com
BITBUCKET_API_TOKEN=your-api-token

# Optional
BITBUCKET_WORKSPACE=your-default-workspace
BITBUCKET_MAX_RESULTS=50

# Legacy (supported until June 9, 2026 — migrate to API tokens above)
# BITBUCKET_USERNAME=your-username
# BITBUCKET_APP_PASSWORD=your-app-password
